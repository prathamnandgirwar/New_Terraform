    agent any
    stages{
        stage("pull"){
            steps{
                echo 'Pull success '
            }
        }
        stage(" build"){
            steps{
                echo 'Build success'
            }
        }
        stage("test"){
            steps{
                echo 'Test complete'
            }
        }
        stage("deploy"){
            steps{
                echo 'Deploy done'
            }
        }
    }
}
